{
  "title": "EMF Router Service",
  "uid": "emf-router",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Notification States",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (state) (emf_notification_state_total)",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Dispatch Latency (p50/p99 by channel)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(emf_notification_dispatch_seconds_bucket[5m]))",
          "legendFormat": "p50 {{channel}}"
        },
        {
          "expr": "histogram_quantile(0.99, rate(emf_notification_dispatch_seconds_bucket[5m]))",
          "legendFormat": "p99 {{channel}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"emf-router\"}[5m])",
          "legendFormat": "{{handler}}"
        }
      ]
    }
  ]
}
