{
  "title": "EMF Form Service",
  "uid": "emf-form",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Cases Submitted (by urgency)",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (urgency) (emf_cases_submitted_total)",
          "legendFormat": "{{urgency}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Submission Attempts (by result)",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum by (result) (emf_form_submission_attempts_total)",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"emf-form\"}[5m])",
          "legendFormat": "{{method}} {{handler}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Request Latency p50/p99",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"emf-form\"}[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"emf-form\"}[5m]))",
          "legendFormat": "p99"
        }
      ]
    }
  ]
}
