# Secrets and local config — never commit these
.env
config.json
infra/secrets/

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
.uv/
*.egg-info/
dist/
build/

# uv
uv.lock          # committed per-service; ignored at root
.python-version

# Test / coverage artefacts
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.swp
*.swo

# Claude Code project memory
.claude/

# TTS model files (large binaries — fetch at deploy time)
*.onnx
*.onnx.json

# Docker build artefacts
*.tar

# PostgreSQL TLS certs (generated at install time)
infra/postgres/certs/

# Audio temp files (TTS service)
apps/tts/audio/

# ZAP scan reports (generated; tracked via reports/zap/.gitkeep)
reports/zap/*.html
reports/zap/*.json

# Backup artefacts
*.dump
*.dump.zst
*.dump.zst.age
