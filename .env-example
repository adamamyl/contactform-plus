# Host port bindings (container-side ports are fixed; these are host-side only)
# The installer checks availability and substitutes a free port if taken.
FORM_PORT=8000
PANEL_PORT=8001
ROUTER_PORT=8002
TTS_PORT=8003
JAMBONZ_PORT=8004

# Database passwords (one per service role)
FORM_DB_PASSWORD=changeme
PANEL_VIEWER_DB_PASSWORD=changeme
TEAM_MEMBER_DB_PASSWORD=changeme
SERVICE_DB_PASSWORD=changeme
ROUTER_DB_PASSWORD=changeme
ADMIN_DB_PASSWORD=changeme
BACKUP_DB_PASSWORD=changeme

# OIDC — production values (UFFD / auth.emfcamp.org)
# For local dev with --profile local, leave these unset: mock-oidc at
# http://oidc.emf-forms.internal/default is used automatically.
OIDC_ISSUER=https://auth.emfcamp.org
OIDC_CLIENT_ID=emf-forms
OIDC_CLIENT_SECRET=changeme

# JWT signing for dispatcher tokens
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changeme

# SMTP password (username lives in config.json)
SMTP_PASSWORD=changeme

# Signal CLI REST API
SIGNAL_SENDER=+440000000000
SIGNAL_API_URL=http://signal-api:8080

# Jambonz telephony
# Get these from your jambonz.cloud account or self-hosted Jambonz admin UI
JAMBONZ_API_URL=https://api.jambonz.cloud
JAMBONZ_API_KEY=changeme
JAMBONZ_ACCOUNT_SID=changeme
JAMBONZ_APPLICATION_SID=changeme
JAMBONZ_FROM_NUMBER=+440000000000

# Override which event the dispatcher shows (bypasses date-based detection)
# CURRENT_EVENT_OVERRIDE=EMF 2026

# Redis (used by panel for dispatcher sessions)
REDIS_PASSWORD=changeme

# Mattermost Posts API (local dev: start with --profile local, then set up a bot)
# MATTERMOST_URL=http://mattermost:8065
# MATTERMOST_CHANNEL_ID=<channel-id-from-api>
# MATTERMOST_TOKEN=<bot-personal-access-token>
# MATTERMOST_WEBHOOK_SECRET=changeme

# Router internal endpoint (shared secret for panel/jambonz → router calls)
ROUTER_INTERNAL_SECRET=changeme

# Resend (for email)
RESEND_API_KEY=changeme
