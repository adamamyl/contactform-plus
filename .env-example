# Host port bindings (container-side ports are fixed; these are host-side only)
# The installer checks availability and substitutes a free port if taken.
FORM_PORT=8000
PANEL_PORT=8001
ROUTER_PORT=8002
TTS_PORT=8003

# Database passwords (one per service role)
FORM_DB_PASSWORD=changeme
PANEL_VIEWER_DB_PASSWORD=changeme
TEAM_MEMBER_DB_PASSWORD=changeme
SERVICE_DB_PASSWORD=changeme
ROUTER_DB_PASSWORD=changeme
ADMIN_DB_PASSWORD=changeme
BACKUP_DB_PASSWORD=changeme

# Public hostnames for Traefik routing (defaults are local dev values)
# Set these on prod to the real public hostnames.
FORM_HOST=report.emf.camp
PANEL_HOST=panel.emf.camp
MAP_HOST=conductmap.emf.camp
SWAGGER_HOST=api.conduct.emf.camp
# OIDC_HOST only needed with --profile local (mock-oidc); leave unset on prod
# OIDC_HOST=oidc.emf-forms.internal

# Compose profiles to activate automatically on `docker compose up -d`
# (comma-separated, no --profile flags needed). Prod wants swagger docs,
# Prometheus/Grafana, and ClamAV attachment scanning running by default:
# COMPOSE_PROFILES=swagger,monitoring,clamav

# OIDC — production values (UFFD / auth.emfcamp.org)
OIDC_ISSUER=https://auth.emfcamp.org
OIDC_CLIENT_ID=emf-forms
OIDC_CLIENT_SECRET=changeme
# Leave OIDC_SERVER_METADATA_URL and OIDC_AUTHORIZE_URL unset on prod: authlib
# uses OIDC_ISSUER for metadata discovery. These are only for local dev with
# --profile local, where OIDC_ISSUER is unreachable from inside the panel
# container — uncomment both to route via the internal mock-oidc hostname:
# OIDC_SERVER_METADATA_URL=http://mock-oidc:8080/default/.well-known/openid-configuration
# OIDC_AUTHORIZE_URL=https://oidc.emf-forms.internal/default/authorize

# JWT signing for dispatcher tokens
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changeme

# SMTP password (username lives in config.json)
SMTP_PASSWORD=changeme

# Signal CLI REST API
SIGNAL_SENDER=+440000000000
SIGNAL_API_URL=http://signal-api:8080


# Override which event the dispatcher shows (bypasses date-based detection)
# CURRENT_EVENT_OVERRIDE=EMF 2026

# Redis (used by panel for dispatcher sessions)
REDIS_PASSWORD=changeme

# Mattermost Posts API (local dev: start with --profile local, then set up a bot)
# MATTERMOST_URL=http://mattermost:8065
# MATTERMOST_CHANNEL_ID=<channel-id-from-api>
# MATTERMOST_TOKEN=<bot-personal-access-token>
# MATTERMOST_WEBHOOK_SECRET=changeme

# Router internal endpoint (shared secret for panel → router calls)
ROUTER_INTERNAL_SECRET=changeme

# EMF Phone System (replaces Jambonz for outbound calling)
# Set emf_phone_mode and emf_phone_targets in config.json per event
EMF_PHONE_API_URL=http://sip2.ix1.inferno.tel:3000
EMF_PHONE_API_KEY=

# Resend (for email)
RESEND_API_KEY=changeme

# Google Safe Browsing — optional, enables URL safety checking on form submission
# Get a key at: https://developers.google.com/safe-browsing/v4/get-started
# Leave blank to disable (submissions with links will not be checked)
GOOGLE_SAFE_BROWSING_API_KEY=
