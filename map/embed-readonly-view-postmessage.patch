 web/src/index.ts  |  9 ++++++--
 web/src/map.ts    | 56 ++++++++++++++++++++++++++++++++++++++++++++++-
 web/src/marker.ts |  9 ++++++++
 4 files changed, 94 insertions(+), 3 deletions(-)

