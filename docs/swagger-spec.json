{
  "info": {
    "name": "EMF Conduct System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "EMF Conduct incident management API. All panel endpoints require a bearer token obtained from the Auth request. Dispatcher endpoints use a separate short-lived JWT passed as ?token=."
  },
  "variable": [
    { "key": "panel_url",                 "value": "https://panel.emf-forms.internal" },
    { "key": "router_url",                "value": "https://router.emf-forms.internal" },
    { "key": "report_url",                "value": "https://report.emf-forms.internal" },
    { "key": "oidc_url",                  "value": "https://oidc.emf-forms.internal" },
    { "key": "tts_url",                   "value": "http://tts:8003" },
    { "key": "jambonz_url",               "value": "http://jambonz:8004" },
    { "key": "access_token",              "value": "" },
    { "key": "dispatcher_token",          "value": "" },
    { "key": "mattermost_webhook_secret", "value": "" },
    { "key": "router_internal_secret",    "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Bearer Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.environment.set('access_token', pm.response.json().access_token);"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "panel", "type": "string" },
                { "key": "password", "value": "{{oidc_client_secret}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "client_credentials" },
                { "key": "scope",      "value": "openid email profile groups" }
              ]
            },
            "url": {
              "raw": "{{oidc_url}}/default/token",
              "host": ["{{oidc_url}}"],
              "path": ["default", "token"]
            }
          }
        }
      ]
    },
    {
      "name": "Panel — Cases",
      "item": [
        {
          "name": "List Cases",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{panel_url}}/api/v1/cases?limit=50&offset=0",
              "host": ["{{panel_url}}"],
              "path": ["api", "v1", "cases"],
              "query": [
                { "key": "limit",   "value": "50", "description": "Max items (1-200, default 50)" },
                { "key": "offset",  "value": "0",  "description": "Pagination offset" },
                { "key": "status",  "value": "",   "description": "Filter: new|assigned|in_progress|action_needed|decision_needed|closed", "disabled": true },
                { "key": "urgency", "value": "",   "description": "Filter: low|medium|high|urgent", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Case",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{panel_url}}/api/v1/cases/:case_id",
              "host": ["{{panel_url}}"],
              "path": ["api", "v1", "cases", ":case_id"],
              "variable": [{ "key": "case_id", "value": "" }]
            }
          }
        },
        {
          "name": "Get Case History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{panel_url}}/api/v1/cases/:case_id/history",
              "host": ["{{panel_url}}"],
              "path": ["api", "v1", "cases", ":case_id", "history"],
              "variable": [{ "key": "case_id", "value": "" }]
            }
          }
        },
        {
          "name": "Lookup Case",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{panel_url}}/api/v1/cases/lookup",
              "host": ["{{panel_url}}"],
              "path": ["api", "v1", "cases", "lookup"],
              "query": [
                { "key": "friendly_id", "value": "", "description": "Human-readable ID (e.g. brave-mango)", "disabled": true },
                { "key": "id",          "value": "", "description": "UUID case ID", "disabled": true }
              ]
            },
            "description": "Look up a case by friendly_id or UUID. Exactly one query param required."
          }
        },
        {
          "name": "Update Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"assigned\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{panel_url}}/api/v1/cases/:case_id/status",
              "host": ["{{panel_url}}"],
              "path": ["api", "v1", "cases", ":case_id", "status"],
              "variable": [{ "key": "case_id", "value": "" }]
            },
            "description": "Valid transitions: new→assigned; assigned→in_progress|new|closed; in_progress→action_needed|decision_needed|closed; action_needed→in_progress|decision_needed|closed; decision_needed→closed|in_progress"
          }
        },
        {
          "name": "Update Urgency",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"urgency\": \"high\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{panel_url}}/api/v1/cases/:case_id/urgency",
              "host": ["{{panel_url}}"],
              "path": ["api", "v1", "cases", ":case_id", "urgency"],
              "variable": [{ "key": "case_id", "value": "" }]
            },
            "description": "Urgency levels: low | medium | high | urgent"
          }
        },
        {
          "name": "Update Assignee",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"assignee\": \"alice\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{panel_url}}/api/v1/cases/:case_id/assignee",
              "host": ["{{panel_url}}"],
              "path": ["api", "v1", "cases", ":case_id", "assignee"],
              "variable": [{ "key": "case_id", "value": "" }]
            },
            "description": "Set to a username string, or null to unassign"
          }
        },
        {
          "name": "Update Tags",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"tags\": [\"noise\", \"welfare\"]}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{panel_url}}/api/v1/cases/:case_id/tags",
              "host": ["{{panel_url}}"],
              "path": ["api", "v1", "cases", ":case_id", "tags"],
              "variable": [{ "key": "case_id", "value": "" }]
            }
          }
        },
        {
          "name": "Get Attachment",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{panel_url}}/cases/:case_id/attachments/:filename",
              "host": ["{{panel_url}}"],
              "path": ["cases", ":case_id", "attachments", ":filename"],
              "variable": [
                { "key": "case_id",  "value": "" },
                { "key": "filename", "value": "", "description": "e.g. abc123.jpg" }
              ]
            },
            "description": "Serves a case attachment. Requires bearer auth (conduct team only). Returns the image file directly."
          }
        },
        {
          "name": "Acknowledge Case",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{panel_url}}/api/v1/cases/:case_id/ack",
              "host": ["{{panel_url}}"],
              "path": ["api", "v1", "cases", ":case_id", "ack"],
              "variable": [{ "key": "case_id", "value": "" }]
            },
            "description": "Marks all notifications for this case as acked and sets assignee to the authenticated user"
          }
        },
        {
          "name": "Trigger Call",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{panel_url}}/api/v1/cases/:case_id/calls",
              "host": ["{{panel_url}}"],
              "path": ["api", "v1", "cases", ":case_id", "calls"],
              "variable": [{ "key": "case_id", "value": "" }]
            },
            "description": "Re-triggers the notification dispatch pipeline via pg_notify"
          }
        }
      ]
    },
    {
      "name": "Panel — Lookup Lists",
      "item": [
        {
          "name": "List Assignees",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{panel_url}}/api/v1/assignees",
              "host": ["{{panel_url}}"],
              "path": ["api", "v1", "assignees"]
            }
          }
        },
        {
          "name": "List Tags",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{panel_url}}/api/v1/tags",
              "host": ["{{panel_url}}"],
              "path": ["api", "v1", "tags"]
            }
          }
        }
      ]
    },
    {
      "name": "Panel — Dispatcher Sessions",
      "item": [
        {
          "name": "Create Dispatcher Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var url = pm.response.json().url;",
                  "var token = url.split('token=')[1];",
                  "if (token) pm.environment.set('dispatcher_token', token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"send_to\": null}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{panel_url}}/api/v1/dispatcher/sessions",
              "host": ["{{panel_url}}"],
              "path": ["api", "v1", "dispatcher", "sessions"]
            },
            "description": "Creates a time-limited dispatcher JWT. Returns URL with embedded token. Post-request script stores the token in dispatcher_token."
          }
        },
        {
          "name": "Revoke Dispatcher Session",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{panel_url}}/api/v1/dispatcher/sessions/:jti",
              "host": ["{{panel_url}}"],
              "path": ["api", "v1", "dispatcher", "sessions", ":jti"],
              "variable": [{ "key": "jti", "value": "", "description": "JWT ID from dispatcher token payload" }]
            },
            "description": "Returns 204 No Content on success"
          }
        }
      ]
    },
    {
      "name": "Panel — Dispatcher (token auth)",
      "description": "These endpoints authenticate via ?token= (dispatcher JWT), not the bearer token. Auth is set to noauth on each request.",
      "item": [
        {
          "name": "List Dispatcher Cases",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{panel_url}}/api/v1/dispatcher/cases?token={{dispatcher_token}}",
              "host": ["{{panel_url}}"],
              "path": ["api", "v1", "dispatcher", "cases"],
              "query": [
                { "key": "token", "value": "{{dispatcher_token}}" },
                { "key": "all",   "value": "false", "description": "Include already-assigned cases", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Dispatcher Acknowledge Case",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"acked_by\": \"dispatcher\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{panel_url}}/api/v1/dispatcher/cases/:case_id/ack?token={{dispatcher_token}}",
              "host": ["{{panel_url}}"],
              "path": ["api", "v1", "dispatcher", "cases", ":case_id", "ack"],
              "query": [{ "key": "token", "value": "{{dispatcher_token}}" }],
              "variable": [{ "key": "case_id", "value": "" }]
            }
          }
        },
        {
          "name": "Dispatcher Trigger Call",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{panel_url}}/api/v1/dispatcher/cases/:case_id/calls?token={{dispatcher_token}}",
              "host": ["{{panel_url}}"],
              "path": ["api", "v1", "dispatcher", "cases", ":case_id", "calls"],
              "query": [{ "key": "token", "value": "{{dispatcher_token}}" }],
              "variable": [{ "key": "case_id", "value": "" }]
            }
          }
        }
      ]
    },
    {
      "name": "Report Form",
      "item": [
        {
          "name": "Submit Incident Report",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Idempotency-Key", "value": "{{$guid}}", "description": "Optional: prevents duplicate submissions on retry" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_name\": \"EMF 2026\",\n  \"what_happened\": \"A brief description of the incident\",\n  \"urgency\": \"medium\",\n  \"can_contact\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{report_url}}/api/submit",
              "host": ["{{report_url}}"],
              "path": ["api", "submit"]
            },
            "description": "Returns 201 with {friendly_id} on success. 200 if idempotency key matches a prior submission."
          }
        },
        {
          "name": "Upload Attachment",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "description": "JPEG, PNG, GIF, or WebP. Max 10 MB." }
              ]
            },
            "url": {
              "raw": "{{report_url}}/attachments?case_id=",
              "host": ["{{report_url}}"],
              "path": ["attachments"],
              "query": [{ "key": "case_id", "value": "", "description": "UUID from submit response" }]
            },
            "description": "Upload an image attachment for a case. Returns {id, case_id}. Max 5 attachments per case. Accepts JPEG, PNG, GIF, WebP."
          }
        },
        {
          "name": "Form Health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{report_url}}/health",
              "host": ["{{report_url}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Message Router",
      "item": [
        {
          "name": "Router Health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{router_url}}/health",
              "host": ["{{router_url}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "Signal Webhook",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"envelope\": {\"source\": \"+441234567890\", \"dataMessage\": {\"reaction\": {\"emoji\": \"\\ud83e\\udd19\", \"targetSentTimestamp\": \"\"}}}}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{router_url}}/webhook/signal",
              "host": ["{{router_url}}"],
              "path": ["webhook", "signal"]
            },
            "description": "Called by Signal CLI on incoming reactions. Emoji 🤙 = ACK. targetSentTimestamp must match a known notification message_id."
          }
        },
        {
          "name": "Mattermost Action Webhook",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Webhook-Secret", "value": "{{mattermost_webhook_secret}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"user_name\": \"alice\", \"context\": {\"action\": \"ack\", \"case_id\": \"\", \"secret\": \"{{mattermost_webhook_secret}}\"}}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{router_url}}/webhook/mattermost/action",
              "host": ["{{router_url}}"],
              "path": ["webhook", "mattermost", "action"]
            },
            "description": "Called by Mattermost interactive button. Returns {update: {message}} to update the post."
          }
        },
        {
          "name": "Email ACK Magic Link",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{router_url}}/ack/:token",
              "host": ["{{router_url}}"],
              "path": ["ack", ":token"],
              "variable": [{ "key": "token", "value": "", "description": "Signed JWT from the email ACK link" }]
            },
            "description": "Clicked from the conduct email. Verifies the signed token, marks the case acked, returns HTML confirmation."
          }
        }
      ]
    },
    {
      "name": "Router (Internal)",
      "description": "Internal router endpoints — only reachable on the Docker network. Require X-Internal-Secret header matching ROUTER_INTERNAL_SECRET.",
      "item": [
        {
          "name": "Internal ACK",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Internal-Secret", "value": "{{router_internal_secret}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"acked_by\": \"jambonz_dtmf\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{router_url}}/internal/ack/:case_id",
              "host": ["{{router_url}}"],
              "path": ["internal", "ack", ":case_id"],
              "variable": [{ "key": "case_id", "value": "" }]
            },
            "description": "Called by Jambonz adapter (DTMF ACK) and panel dispatcher. Optional notification_id to ack a specific notification; omit to ack all for the case."
          }
        }
      ]
    },
    {
      "name": "TTS Service",
      "description": "Internal Piper text-to-speech service (port 8003). Not exposed publicly — accessed by the router and Jambonz adapter on the Docker network.",
      "item": [
        {
          "name": "Synthesise (stream)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"friendly_id\": \"brave-mango\", \"urgency\": \"high\", \"location_hint\": \"Main stage\", \"include_dtmf\": true}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{tts_url}}/synthesise",
              "host": ["{{tts_url}}"],
              "path": ["synthesise"]
            },
            "description": "Returns a streaming audio/wav response. Provide either text OR (friendly_id + urgency). location_hint and include_dtmf are optional."
          }
        },
        {
          "name": "Synthesise to File",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"friendly_id\": \"brave-mango\", \"urgency\": \"high\", \"location_hint\": \"Main stage\", \"include_dtmf\": true}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{tts_url}}/synthesise/file",
              "host": ["{{tts_url}}"],
              "path": ["synthesise", "file"]
            },
            "description": "Synthesises and caches to a temp file. Returns {audio_url} token valid for 5 minutes. Used by Jambonz to get a fetchable URL."
          }
        },
        {
          "name": "Serve Audio",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{tts_url}}/audio/:token",
              "host": ["{{tts_url}}"],
              "path": ["audio", ":token"],
              "variable": [{ "key": "token", "value": "", "description": "Token from /synthesise/file response" }]
            },
            "description": "Returns the cached WAV file. 404 if expired or not found."
          }
        },
        {
          "name": "TTS Health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{tts_url}}/health",
              "host": ["{{tts_url}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Jambonz Adapter",
      "description": "Telephony adapter (port 8004). Webhooks are called by Jambonz cloud.",
      "item": [
        {
          "name": "Jambonz Call Webhook",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"call_sid\": \"\", \"call_status\": \"trying\", \"digits\": \"\", \"tag\": {}}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{jambonz_url}}/webhook/jambonz/call?case_id=&audio_url=",
              "host": ["{{jambonz_url}}"],
              "path": ["webhook", "jambonz", "call"],
              "query": [
                { "key": "case_id",   "value": "", "description": "UUID of the case" },
                { "key": "audio_url", "value": "", "description": "TTS audio URL" }
              ]
            },
            "description": "Jambonz fires this when a call needs instructions or digits are pressed. Press 1 to ACK."
          }
        },
        {
          "name": "Jambonz Status Webhook",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"call_sid\": \"\", \"call_status\": \"completed\", \"digits\": \"\", \"tag\": {}}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{jambonz_url}}/webhook/jambonz/status",
              "host": ["{{jambonz_url}}"],
              "path": ["webhook", "jambonz", "status"]
            },
            "description": "Jambonz fires this for every call state change. Must always return {} — returning verbs causes call termination."
          }
        },
        {
          "name": "Proxy Audio (GET)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{jambonz_url}}/audio/:filename",
              "host": ["{{jambonz_url}}"],
              "path": ["audio", ":filename"],
